# ──────────────────────────────────────────────────────────────────────────────
# Konfiguracja podpisu release — NIGDY NIE COMMITUJ TEGO PLIKU!
# ──────────────────────────────────────────────────────────────────────────────
# Skopiuj ten plik jako 'keystore.properties' i uzupełnij prawdziwe wartości.
# Plik keystore.properties jest w .gitignore i nigdy nie trafi do repo.
#
# storeFile     = ścieżka do pliku klucza (np. J:\\klucz\\klucz_kinobot)
# storePassword = hasło do keystore
# keyPassword   = hasło do klucza
# keyAlias      = alias klucza
# ──────────────────────────────────────────────────────────────────────────────

storeFile=SCIEZKA_DO_KLUCZA
storePassword=TWOJE_HASLO
keyPassword=TWOJE_HASLO
keyAlias=TWOJ_ALIAS
