<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="8dp"
    app:strokeWidth="1dp"
    app:strokeColor="#33FFFFFF"
    app:cardBackgroundColor="#22000000">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <!-- Tytuł — przypięty do góry -->
        <TextView
            android:id="@+id/tv_analytics_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Analityka Godzin"
            android:textSize="12sp"
            android:textColor="#FF6600"
            android:textAllCaps="true"
            android:letterSpacing="0.08"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Tekst podsumowania — przypięty do dołu -->
        <TextView
            android:id="@+id/tv_donut_fraction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BAR: 0.0h  |  OW: 0.0h"
            android:textSize="14sp"
            android:textColor="#DDDDDD"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Wykres — wypełnia przestrzeń między tytułem a tekstem -->
        <com.github.mikephil.charting.charts.PieChart
            android:id="@+id/chart_hours_donut"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            app:layout_constraintTop_toBottomOf="@id/tv_analytics_title"
            app:layout_constraintBottom_toTopOf="@id/tv_donut_fraction"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
