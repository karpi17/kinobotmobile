<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_stack_item_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="10dp"
    android:background="#2A2A2A"
    android:gravity="center_vertical">

    <!-- Data + stanowisko (chip) w jednym wierszu -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_stack_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Dziś"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />

        <TextView
            android:id="@+id/widget_stack_category"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BAR"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="#FF6600"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp" />
    </LinearLayout>

    <!-- Godziny -->
    <TextView
        android:id="@+id/widget_stack_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="14:00 – 22:00"
        android:textSize="12sp"
        android:textColor="#CCCCCC"
        android:layout_marginTop="4dp" />

    <!-- Alarm + ekipa w jednym wierszu -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_stack_alarm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔔 "
            android:textSize="11sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/widget_stack_crew"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textSize="11sp"
            android:textColor="#AAAAAA"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

</LinearLayout>
