<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Imię — AutoComplete z podpowiedziami ze słownika -->
    <AutoCompleteTextView
        android:id="@+id/et_new_coworker_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Imię i Nazwisko"
        android:inputType="textPersonName"
        android:completionThreshold="1"
        android:dropDownWidth="match_parent"
        android:popupBackground="#2A2A2A"
        android:layout_marginBottom="12dp"/>

    <!-- Godziny: Start | Koniec -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <EditText
            android:id="@+id/et_new_coworker_start"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Od (np. 08:00)"
            android:inputType="time"
            android:layout_marginEnd="8dp"/>

        <EditText
            android:id="@+id/et_new_coworker_end"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Do (np. 16:00)"
            android:inputType="time"/>
    </LinearLayout>

    <!-- Stanowisko -->
    <EditText
        android:id="@+id/et_new_coworker_position"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Stanowisko (np. BAR, OW)"
        android:inputType="text"
        android:maxLines="1" />

</LinearLayout>