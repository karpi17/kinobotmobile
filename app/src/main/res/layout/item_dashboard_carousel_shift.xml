<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="?attr/colorSurfaceVariant"
    app:cardBackgroundColor="?attr/colorSurface">

    <LinearLayout
        android:id="@+id/layout_next_shift_data"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Najbliższa zmiana"
            android:textAppearance="?attr/textAppearanceLabelMedium"
            android:textColor="?attr/colorPrimary"
            android:textAllCaps="true"
            android:layout_marginBottom="8dp" />

        <!-- Wiersz: data + 🌙 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_next_shift_date"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Jutro"
                android:textAppearance="?attr/textAppearanceHeadline5"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface" />

            <TextView
                android:id="@+id/tv_carousel_moon_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌙"
                android:textSize="20sp"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_next_shift_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="14:00 - 22:30"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_next_shift_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BAR"
            android:textSize="16sp"
            android:paddingVertical="4dp"
            android:paddingHorizontal="8dp"
            app:chipMinHeight="0dp"
            app:chipBackgroundColor="#FF6600"
            android:textColor="#FFFFFF" />

        <!-- Ekipa zamykająca — widoczna warunkowo -->
        <TextView
            android:id="@+id/tv_carousel_closing_crew"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textSize="13sp"
            android:textColor="?android:attr/textColorSecondary"
            android:visibility="gone" />

        <!-- Współpracownicy (overlap z global_shifts) — widoczna warunkowo -->
        <View
            android:id="@+id/divider_coworkers"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#333333"
            android:layout_marginTop="10dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_carousel_coworkers_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👥 Współpracownicy"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#FF6600"
            android:layout_marginTop="6dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_carousel_coworkers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="11sp"
            android:textColor="?android:attr/textColorSecondary"
            android:lineSpacingMultiplier="1.3"
            android:visibility="gone" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_no_next_shift"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center"
        android:visibility="gone">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_today"
            app:tint="?android:attr/textColorSecondary"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Brak zaplanowanych zmian"
            android:textAppearance="?attr/textAppearanceBodyLarge"
            android:textColor="?android:attr/textColorSecondary" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
